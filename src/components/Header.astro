---
const { pathname } = Astro.url;
const links = [
  { href: '/', label: 'Home' },
  { href: '/clients', label: 'Clients' },
  { href: '/about-me', label: 'About' },
];
function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---
<header class="site-header">
  <div class="max-w-page mx-auto px-6 py-5 flex items-center justify-between gap-8">
    <a href="/" class="site-title-mark text-xl md:text-[1.35rem]">
      PJ Srivastava
    </a>
    <nav aria-label="Primary">
      <ul class="flex items-center gap-7 md:gap-9">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class={`nav-link ${isActive(l.href) ? 'active' : ''}`}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
