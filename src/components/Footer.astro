---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="max-w-page mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
    <p class="text-muted">© {year} PJ Srivastava. All rights reserved.</p>
    <nav aria-label="Secondary">
      <ul class="flex items-center gap-7">
        <li>
          <a
            href="https://www.linkedin.com/in/pjsrivastava/"
            class="footer-link footer-link--icon"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="PJ Srivastava on LinkedIn"
          >
            <svg
              class="footer-icon"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
              focusable="false"
            >
              <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45C23.2 24 24 23.23 24 22.28V1.72C24 .77 23.2 0 22.23 0z"/>
            </svg>
            <span>LinkedIn</span>
          </a>
        </li>
        <li>
          <a href="#top" class="footer-link">Back to top</a>
        </li>
      </ul>
    </nav>
  </div>
</footer>
