---
import BaseLayout from '../layouts/BaseLayout.astro';

interface ClientSection {
  name: string;
  overviewBullets?: string[];
  sampleWork?: string[];
}

const clients: ClientSection[] = [
  {
    name: 'Q Software Development LLC (dba Quarem)',
    overviewBullets: [
      'Led turn-around effort for SaaS startup challenged with product development issues and onboarding Fortune 500 and large client companies.',
      'Recruited new development team, including a new Chief Technology Officer, and put Agile processes in place; improved release times from a few times a year to every three weeks.',
      'Wrote documentation for and implemented organizational processes to successfully pass a SOC I Type I and Type II audit.',
      'Process improvements and team-building led to a doubling of revenue within a one-year time span.',
      'Successfully coached and mentored organization to be self-sustaining.',
    ],
  },
  {
    name: 'American Express (long-term contract)',
    sampleWork: [
      'Custom integration between Salesforce CRM and Sitecore CMS for 28 multi-lingual websites localized for different countries.',
      'Developed custom newsletter application with article previews, categorization, intelligent search, and social sharing functionality.',
      'Developed secure JavaScript form embeddable in third-party websites for lead generation.',
      'Developed interactive wizard for selecting appropriate card product based on user-answered questions.',
      'Implementation of detailed site analytics and campaign tracking.',
    ],
  },
  {
    name: 'TXU Energy (long-term contract)',
    sampleWork: [
      'Custom integration between enterprise SAP implementation and Sitecore CMS.',
      'Developed My Energy Dashboard web portal for customers to monitor their electricity usage and billing details.',
      'Developed interface and functionality for online bill payment and signing up for or changing plans online.',
      'Developed custom plan finder with searching, filtering, and comparison features for users to find the right plan for their needs.',
      'Developed iOS and Android applications with comparable desktop functionality.',
    ],
  },
  {
    name: 'Novo Nordisk (long-term contract)',
    sampleWork: [
      'Repaired an incomplete site migration into Adobe Experience Manager CMS and rebuilt its connection to a legacy SQL Server database using .NET web services.',
      'Designed new customer web portal to track articles read and suggest new articles to read.',
      'Developed application for tracking diabetes indicators, medication, and doctor visits, and suggesting a personalized wellness plan.',
      'Developed HIPAA-compliant registration forms for collecting patient and caregiver information, as well as medication information.',
    ],
  },
  {
    name: 'Horizon Therapeutics (long-term contract)',
    sampleWork: [
      'Migration, redesign, and enhancement of 15+ sites within CrownPeak CMS.',
      'Program management of multiple website portfolios, email campaigns, and social media advertising.',
      'Management of copywriting, design, UX, and medical/legal compliance processes for new site builds and existing site redesigns.',
      'Developed application for self-assessment of medical symptoms and generating custom report to share with doctors for follow-up.',
      'Trained team and stakeholders on development approach using a shared component library to increase the speed and decrease the cost of website maintenance and new development.',
    ],
  },
  {
    name: 'MRC Global (long-term contract)',
    sampleWork: [
      'Design and development of a single corporate website to consolidate 8+ smaller company websites, including new branding, content, functionality, and user experience.',
      'Developed custom location finder with Google Maps API integration, zip-code, city, state, country, and keyword search, and autocomplete.',
      'Developed custom site localization features to segment product and service offerings by three different regions and 16 different countries.',
      'Developed custom product template with previews, image gallery, categorization, and dynamic content.',
      'Developed custom online newsletter and blogging system for self-administration of online marketing campaigns.',
    ],
  },
  {
    name: 'Golden1 Credit Union (short-term contract)',
    sampleWork: [
      'Rebuild, redesign, and functional enhancement of legacy site using Sitecore CMS.',
      'Retool of front-end technologies to implement responsive design and ADA compliance.',
      'Third-party API integration with external CRM for sending and querying data.',
      'Development of custom event calendar and registration system.',
      'Enhancement of location finder to include geolocation, filtering, and smart search.',
    ],
  },
  {
    name: 'Orvis (short-term contract)',
    sampleWork: [
      'Implementation of advanced site personalization and A/B testing features using Adobe Marketing Cloud technologies.',
      'Automation of production workflows for generating new product pages.',
      'Enhanced site search with granular keyword targeting, relevancy weighting, suggested search, results-list previews, and advanced analytics.',
    ],
  },
  {
    name: 'Assorted Small/Medium-Sized Companies (5 year period)',
    overviewBullets: [
      'Prior to working with large companies, I spent several years consulting for startups and local businesses. Despite their smaller size, some of them had the most interesting, varied, and innovative projects to work on!',
    ],
    sampleWork: [
      'Web portals / dashboards',
      'Server migrations / hosting setup',
      'CMS implementations',
      'CRM implementations',
      'E-commerce implementations',
      'ERP implementations',
      'SaaS development',
      'Product configurators',
      'Mobile applications',
      'Kiosk software',
      'Email marketing',
      'A/B testing',
      'Workflow automation',
      'Custom APIs / web services',
      'Interactive media',
    ],
  },
];
---
<BaseLayout
  title="Clients"
  description="A sample of the client projects PJ Srivastava has worked on across a career in digital agencies and SaaS."
>
  <article class="max-w-prose mx-auto">
    <header class="mb-10 pb-8 border-b border-rule">
      <p class="article-eyebrow">Experience</p>
      <h1 class="article-title">A Sample of the Client Projects I've Worked On</h1>
      <p class="mt-5 text-lg md:text-xl text-inkMute leading-relaxed italic font-serif">
        Sixteen years across three digital agencies and one SaaS startup — plus earlier
        stints as a developer, UX designer, and product manager.
      </p>
    </header>

    <div class="prose">
      <p>
        My in-the-trenches experience includes being a consultant for three different
        digital agencies and one SaaS startup over a 16-year period, as well as having
        been a former software developer, UX designer, and product manager.
      </p>
      <p>Below are some of the companies and types of projects I've managed.</p>
    </div>

    {clients.map((c) => (
      <section class="mt-14 pt-10 border-t border-rule">
        <h2 class="font-serif text-2xl md:text-3xl leading-tight text-ink" style="font-weight: 500; letter-spacing: -0.01em;">
          {c.name}
        </h2>
        <div class="prose mt-5">
          {c.overviewBullets && c.overviewBullets.length > 0 && (
            <>
              {c.sampleWork && <h3>Overview</h3>}
              <ul>
                {c.overviewBullets.map((b) => <li>{b}</li>)}
              </ul>
            </>
          )}
          {c.sampleWork && c.sampleWork.length > 0 && (
            <>
              <h3>Sample project work</h3>
              <ul>
                {c.sampleWork.map((b) => <li>{b}</li>)}
              </ul>
            </>
          )}
        </div>
      </section>
    ))}
  </article>
</BaseLayout>
